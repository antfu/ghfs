{
  "name": "@ghfs/cli",
  "type": "module",
  "version": "0.0.0",
  "packageManager": "pnpm@10.30.3",
  "description": "GitHub issues/PRs as filesystem, for offline view and operations in batch. Designed for human and agents.",
  "author": "Anthony Fu <anthonyfu117@hotmail.com>",
  "license": "MIT",
  "funding": "https://github.com/sponsors/antfu",
  "homepage": "https://github.com/antfu/ghfs",
  "repository": "https://github.com/antfu/ghfs",
  "bugs": "https://github.com/antfu/ghfs/issues",
  "keywords": [
    "github",
    "issues",
    "pull requests",
    "markdown",
    "cli"
  ],
  "exports": {
    ".": "./dist/index.mjs",
    "./cli": "./dist/cli.mjs",
    "./package.json": "./package.json"
  },
  "types": "./dist/index.d.mts",
  "bin": {
    "ghfs": "./dist/cli.mjs"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "start": "tsx src/cli.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "eslint",
    "release": "bumpp",
    "play": "cd playgrounds/ni && tsx ../../src/cli.ts",
    "prepare": "git submodule update --init --recursive && simple-git-hooks"
  },
  "dependencies": {
    "@clack/prompts": "^1.1.0",
    "@octokit/plugin-retry": "^8.1.0",
    "@octokit/plugin-throttling": "^11.0.3",
    "ansis": "^4.2.0",
    "cac": "^7.0.0",
    "dotenv": "^17.3.1",
    "jiti": "^2.6.1",
    "octokit": "^5.0.5",
    "pathe": "^2.0.3",
    "valibot": "^1.1.0",
    "yaml": "^2.8.2"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^7.6.1",
    "@types/node": "^25.3.3",
    "bumpp": "^10.4.1",
    "eslint": "^10.0.2",
    "lint-staged": "^16.3.2",
    "simple-git-hooks": "^2.13.1",
    "tsdown": "^0.20.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm i --frozen-lockfile --ignore-scripts --offline && npx lint-staged"
  },
  "lint-staged": {
    "*": "eslint --fix"
  }
}
