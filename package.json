{
  "name": "@ghfs/cli",
  "type": "module",
  "version": "0.0.3",
  "packageManager": "pnpm@10.30.3",
  "description": "GitHub issues/PRs as filesystem, for offline view and operations in batch. Designed for human and agents.",
  "author": "Anthony Fu <anthonyfu117@hotmail.com>",
  "license": "MIT",
  "funding": "https://github.com/sponsors/antfu",
  "homepage": "https://github.com/antfu/ghfs",
  "repository": "https://github.com/antfu/ghfs",
  "bugs": "https://github.com/antfu/ghfs/issues",
  "keywords": [
    "github",
    "issues",
    "pull requests",
    "markdown",
    "cli"
  ],
  "exports": {
    ".": "./dist/index.mjs",
    "./cli": "./dist/cli.mjs",
    "./package.json": "./package.json"
  },
  "types": "./dist/index.d.mts",
  "bin": {
    "ghfs": "./dist/cli.mjs"
  },
  "files": [
    "dist",
    "skills/ghfs"
  ],
  "scripts": {
    "build": "pnpm run build:ts && pnpm run build:ui && pnpm run copy:ui",
    "build:ts": "tsdown",
    "build:ui": "cd ui && nuxt generate",
    "dev:ui": "cd ui && nuxt dev",
    "copy:ui": "node scripts/copy-ui.mjs",
    "start": "tsx src/cli.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "coverage": "vitest run --coverage",
    "lint": "eslint",
    "release": "bumpp",
    "prepublishOnly": "pnpm run build",
    "play": "cd playgrounds/ni && tsx ../../src/cli.ts",
    "prepare": "git submodule update --init --recursive && simple-git-hooks"
  },
  "dependencies": {
    "@clack/prompts": "^1.1.0",
    "@octokit/plugin-retry": "^8.1.0",
    "@octokit/plugin-throttling": "^11.0.3",
    "ansis": "^4.2.0",
    "birpc": "^4.0.0",
    "cac": "^7.0.0",
    "dotenv": "^17.3.1",
    "jiti": "^2.6.1",
    "octokit": "^5.0.5",
    "pathe": "^2.0.3",
    "structured-clone-es": "^1.0.0",
    "valibot": "^1.2.0",
    "ws": "^8.19.0",
    "yaml": "^2.8.2"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^7.6.1",
    "@antfu/ni": "^28.2.0",
    "@types/node": "^25.3.5",
    "@types/ws": "^8.18.1",
    "@unocss/nuxt": "^66.6.5",
    "@vitest/coverage-v8": "4.0.18",
    "@vueuse/core": "^14.2.1",
    "@vueuse/nuxt": "^14.2.1",
    "bumpp": "^10.4.1",
    "eslint": "^10.0.2",
    "lint-staged": "^16.3.2",
    "nuxt": "^4.3.1",
    "reka-ui": "^2.9.0",
    "simple-git-hooks": "^2.13.1",
    "tsdown": "^0.20.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "unocss": "^66.6.5",
    "vite": "^8.0.0-beta.16",
    "vitest": "^4.0.18",
    "vue": "^3.5.29"
  },
  "resolutions": {
    "chokidar": "^5.0.0",
    "semver": "^7.7.4",
    "vite": "^8.0.0-beta.16"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm i --frozen-lockfile --ignore-scripts --offline && npx lint-staged"
  },
  "lint-staged": {
    "*": "eslint --fix"
  }
}
